        },
        {
            "paragraph": 3,
            "sentance_id": 5,
            "sentence_md5": "3496eee82bdda70cf18d5cd29cc10b98",
            "sentance": "Why is student cheating on the rise?",
            "phonetic": "/waɪ ɪz ˈstjuːdnt ˈtʃiːtɪŋ ɒn ðə raɪz?/",
            "translation": "为什么学生作弊现象在上升？",
            "audio_file": "data/audio/3496eee82bdda70cf18d5cd29cc10b98.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": [
                    {
                        "phrase": "on the rise",
                        "meaning": "正在上升"
                    }
                ]
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 6,
            "sentence_md5": "b1de5f46dcce70ac7dc910164d911ab9",
            "sentance": "No one really knows.",
            "phonetic": "/nəʊ wʌn ˈriːəli nəʊz./",
            "translation": "没有人真正知道。",
            "audio_file": "data/audio/b1de5f46dcce70ac7dc910164d911ab9.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 7,
            "sentence_md5": "7dc09d29b1373b4642a58f9713d8ea40",
            "sentance": "Some blame the trend on a general loosening to the fact that today’s youth are far more pragmatic than their more idealistic predecessors.",
            "phonetic": "/sʌm bleɪm ðə trend ɒn ə ˈdʒenrəl ˈluːsənɪŋ tə ðə fækt ðæt təˈdeɪz juːθ ɑː(r) fɑː(r) mɔː(r) præɡˈmætɪk ðæn ðeə(r) mɔː(r) ˌaɪdiəˈlɪstɪk ˈpriːdɪsesəz./",
            "translation": "一些人将这种趋势归咎于一种普遍的松懈，即今天的年轻人在很大程度上比他们理想主义的前辈更加务实。",
            "audio_file": "data/audio/7dc09d29b1373b4642a58f9713d8ea40.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [
                    {
                        "word": "pragmatic",
                        "phonetic": "/præɡˈmætɪk/",
                        "meaning": "adj. 务实的"
                    },
                    {
                        "word": "idealistic",
                        "phonetic": "/ˌaɪdiəˈlɪstɪk/",
                        "meaning": "adj. 理想主义的"
                    },
                    {
                        "word": "predecessor",
                        "phonetic": "/ˈpriːdɪsesə(r)/",
                        "meaning": "n. 前辈"
                    }
                ],
                "phrases": [
                    {
                        "phrase": "blame ... on",
                        "meaning": "把...归咎于"
                    }
                ]
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 8,
            "sentence_md5": "abfbb9657ef3d6de53f343866bb74773",
            "sentance": "Whereas in the late sixties and early seventies, students were filled with visions about changing the world, today’s students feel great pressure to conform and succeed.",
            "phonetic": "/ˌweərˈæz ɪn ðə leɪt ˈsɪkstiz ænd ˈɜːli ˈsevntiz, ˈstjuːdnts wɜː(r) fɪld wɪð ˈvɪʒnz əˈbaʊt ˈtʃeɪndʒɪŋ ðə wɜːld, təˈdeɪz ˈstjuːdnts fiːl ɡreɪt ˈpreʃə(r) tə kənˈfɔːm ænd səkˈsiːd./",
            "translation": "在60年代末和70年代初，学生们充满了改变世界的愿景，而今天的学生则感到遵守规矩和取得成功的巨大压力。",
            "audio_file": "data/audio/abfbb9657ef3d6de53f343866bb74773.mp3",
            "analysis": {
                "long_sentence_analysis": "Whereas引导让步状语从句",
                "core_vocabulary": [
                    {
                        "word": "conform",
                        "phonetic": "/kənˈfɔːm/",
                        "meaning": "v. 顺从，遵从"
                    }
                ],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 9,
            "sentence_md5": "a802cf3f5c1a9e8338b3edb7f794ae12",
            "sentance": "In interviews with tudents feel great pressure to conform and succeed.",
            "phonetic": "",
            "translation": "在采访中，学生感到遵守规矩和取得成功的巨大压力。（这句原文本就有重复）",
            "audio_file": "data/audio/a802cf3f5c1a9e8338b3edb7f794ae12.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 10,
            "sentence_md5": "282db93f72203ae556637acb9fe7c91e",
            "sentance": "In interviews with students at high schools and colleges around the country, both young men and women said that cheating had become easy.",
            "phonetic": "/ɪn ˈɪntəvjuːz wɪð ˈstjuːdnts æt haɪ skuːlz ænd ˈkɒlɪdʒɪz əˈraʊnd ðə ˈkʌntri, bəʊθ jʌŋ men ænd ˈwɪmɪn sed ðæt ˈtʃiːtɪŋ hæd bɪˈkʌm ˈiːzi./",
            "translation": "在对全国各地的中学和大学学生的采访中，年轻男女都表示作弊变得很容易了。",
            "audio_file": "data/audio/282db93f72203ae556637acb9fe7c91e.mp3",
            "analysis": {
                "long_sentence_analysis": "said后面是that引导的宾语从句",
                "core_vocabulary": [],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 11,
            "sentence_md5": "d5ac17613630c26a59bc703a8f770647",
            "sentance": "Some suggested they did it out of spite for teachers they did not respect.",
            "phonetic": "/sʌm səˈdʒestɪd ðeɪ dɪd ɪt aʊt ɒv spaɪt fə(r) ˈtiːtʃəz ðeɪ dɪd nɒt rɪˈspekt./",
            "translation": "一些人暗示，他们这样做是出于对他们不尊重的老师的怨恨。",
            "audio_file": "data/audio/d5ac17613630c26a59bc703a8f770647.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": [
                    {
                        "phrase": "out of spite",
                        "meaning": "出于怨恨"
                    }
                ]
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 12,
            "sentence_md5": "14ae9d3aa1ce4359ad562617a70448bc",
            "sentance": "Others looked at it as a game.",
            "phonetic": "/ˈʌðəz lʊkt æt ɪt æz ə ɡeɪm./",
            "translation": "另一些人把它看作一场游戏。",
            "audio_file": "data/audio/14ae9d3aa1ce4359ad562617a70448bc.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": [
                    {
                        "phrase": "look at ... as",
                        "meaning": "把...看作"
                    }
                ]
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 13,
            "sentence_md5": "cf665a9d76eae94367efad683b8dbe70",
            "sentance": "Only if they were caught, some said, would they feel guilty.",
            "phonetic": "/ˈəʊnli ɪf ðeɪ wɜː(r) kɔːt, sʌm sed, wʊd ðeɪ fiːl ˈɡɪlti./",
            "translation": "有些人说，只有当他们被抓住时，他们才会感到内疚。",
            "audio_file": "data/audio/cf665a9d76eae94367efad683b8dbe70.mp3",
            "analysis": {
                "long_sentence_analysis": "Only if 放在句首引起部分倒装 (would they feel guilty)。",
                "core_vocabulary": [],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 14,
            "sentence_md5": "ee09f171202943f5559e68a272d758b6",
            "sentance": "“People are competitive,” said a second-year college student named Anna, from Chicago.",
            "phonetic": "/ˈpiːpl ɑː(r) kəmˈpetətɪv, sed ə ˈsekənd-jɪə(r) ˈkɒlɪdʒ ˈstjuːdnt neɪmd ˈænə, frɒm ʃɪˈkɑːɡəʊ./",
            "translation": "“人们都是有竞争力的，”一位来自芝加哥的名叫安娜的大二学生说。",
            "audio_file": "data/audio/ee09f171202943f5559e68a272d758b6.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 15,
            "sentence_md5": "dcb8885993d99936ea21af46250e0183",
            "sentance": "There’s an underlying fear.",
            "phonetic": "/ðeəz ən ˌʌndəˈlaɪɪŋ fɪə(r)./",
            "translation": "有一种潜在的恐惧。",
            "audio_file": "data/audio/dcb8885993d99936ea21af46250e0183.mp3",
            "analysis": {
