                    }
                ],
                "phrases": []
            }
        },
        {
            "paragraph": 2,
            "sentance_id": 3,
            "sentence_md5": "c5c7a5acb9280801534dc32b8676106f",
            "sentance": "But today, educators and administrators are finding that instances of academic dishonesty on the part of students have become more frequent and are less likely to be punished than in the past.",
            "phonetic": "/bʌt təˈdeɪ, ˈedʒukeɪtəz ænd ədˈmɪnɪstreɪtəz ɑː(r) ˈfaɪndɪŋ ðæt ˈɪnstənsɪz ɒv ˌækəˈdemɪk dɪsˈɒnɪsti ɒn ðə pɑːt ɒv ˈstjuːdnts həv bɪˈkʌm mɔː(r) ˈfriːkwənt ænd ɑː(r) les ˈlaɪkli tə bi ˈpʌnɪʃt ðæn ɪn ðə pɑːst./",
            "translation": "但是今天，教育工作者和管理者发现，学生方面的学术不诚实事件变得越来越频繁，而且比过去更不可能受到惩罚。",
            "audio_file": "data/audio/c5c7a5acb9280801534dc32b8676106f.mp3",
            "analysis": {
                "long_sentence_analysis": "宾语从句that...中包含一个并列谓语have become... and are less likely to...",
                "core_vocabulary": [
                    {
                        "word": "academic",
                        "phonetic": "/ˌækəˈdemɪk/",
                        "meaning": "adj. 学术的",
                        "context": "academic dishonesty"
                    },
                    {
                        "word": "dishonesty",
                        "phonetic": "/dɪsˈɒnɪsti/",
                        "meaning": "n. 不诚实",
                        "context": "academic dishonesty"
                    }
                ],
                "phrases": [
                    {
                        "phrase": "on the part of",
                        "meaning": "在...方面"
                    }
                ]
            }
        },
        {
            "paragraph": 2,
            "sentance_id": 4,
            "sentence_md5": "90779697b6e8877a93a721870115c906",
            "sentance": "Cheating appears to have gained cceptance among good and poor students alike.",
            "phonetic": "/ˈtʃiːtɪŋ əˈpɪəz tə həv ɡeɪnd /əkˈseptəns/ əˈmʌŋ ɡʊd ænd pʊə(r) ˈstjuːdnts əˈlaɪk./",
            "translation": "作弊似乎在好学生和差生中都获得了认可。",
            "audio_file": "data/audio/90779697b6e8877a93a721870115c906.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [
                    {
