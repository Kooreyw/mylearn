            }
        },
        {
            "paragraph": 3,
            "sentance_id": 16,
            "sentence_md5": "31c06a0ceccd0ed99ad5c547a30ca5c9",
            "sentance": "If you don’t do well, your life is going to be ruined.",
            "phonetic": "/ɪf ju dəʊnt duː wel, jɔː(r) laɪf ɪz ˈɡəʊɪŋ tə bi ˈruːɪnd./",
            "translation": "如果你做得不好，你的一生都毁了。",
            "audio_file": "data/audio/31c06a0ceccd0ed99ad5c547a30ca5c9.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [
                    {
                        "word": "ruin",
                        "phonetic": "/ˈruːɪn/",
                        "meaning": "v. 毁灭"
                    }
                ],
                "phrases": []
            }
        },
        {
            "paragraph": 3,
            "sentance_id": 17,
            "sentence_md5": "ecf17cfee4dc79107850de96c79a9151",
            "sentance": "The pressure is not only from parents and friends but from yourself.",
            "phonetic": "/ðə ˈpreʃə(r) ɪz nɒt ˈəʊnli frɒm ˈpeərənts ænd frendz bʌt frɒm jɔːˈself./",
            "translation": "压力不仅来自父母和朋友，也来自你自己。",
            "audio_file": "data/audio/ecf17cfee4dc79107850de96c79a9151.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [],
                "phrases": [
