            "sentance": "Cheating is nothing new.",
            "phonetic": "/ˈtʃiːtɪŋ ɪz ˈnʌθɪŋ njuː./",
            "translation": "作弊并不是什么新鲜事。",
            "audio_file": "data/audio/8759b6441c976333783d5d35ac96c574.mp3",
            "analysis": {
                "long_sentence_analysis": "",
                "core_vocabulary": [
                    {
